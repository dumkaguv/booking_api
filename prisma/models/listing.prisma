model Listing {
  id Int @id @default(autoincrement())

  title       String  @db.VarChar(255)
  description String? @db.VarChar(255)

  status ListingStatusEnum? @default(DRAFT)
  type   ListingTypeEnum

  country     String @db.VarChar(255)
  city        String @db.VarChar(255)
  addressLine String @map("address_line") @db.VarChar(255)

  basePrice Decimal @map("base_price")
  currency  String  @db.Char(3)

  maxGuests Int @map("max_guests")

  checkInFrom   DateTime @map("check_in_from")
  checkOutUntil DateTime @map("check_out_until")

  instantBook Boolean @map("instant_book")

  ownerId      Int           @map("owner_id")
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  listingUnits ListingUnit[]
  listingFiles ListingFile[]
  amenities    Amenity[]
  bookings     Booking[]
  reviews      Review[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
}

enum ListingStatusEnum {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ListingTypeEnum {
  APARTMENT
  HOUSE
  VILLA
  HOTEL
  HOSTEL
  ROOM
}
