model Booking {
  id Int @id @default(autoincrement())

  unitId Int         @map("unit_id")
  unit   ListingUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)

  guestId Int  @map("guest_id")
  guest   User @relation(fields: [guestId], references: [id], onDelete: Restrict)

  listingId Int?     @map("listing_id")
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  checkIn     DateTime @map("check_in") @db.Date
  checkOut    DateTime @map("check_out") @db.Date
  guestsCount Int      @map("guests_count")

  status BookingStatusEnum @default(PENDING)

  totalAmount Decimal @map("total_amount")
  currency    String  @db.Char(3)

  confirmedAt  DateTime? @map("confirmed_at")
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  bookingDays BookingDay[]
  review      Review?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([unitId])
  @@index([guestId])
  @@index([listingId])
}

enum BookingStatusEnum {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}
